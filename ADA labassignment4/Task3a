def naive_search(text, pattern):
    n, m = len(text), len(pattern)
    count = 0
    
    for i in range(n - m + 1):
        match = True
        for j in range(m):
            count += 1
            if text[i+j] != pattern[j]:
                match = False
                break
        if match:
            print("Pattern found at index", i)
    
    print("Comparisons:", count)

